{
    "name": "@basmilius/apple-companion-link",
    "description": "Implementation of Apple's Companion Link",
    "version": "0.0.7",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "keywords": [
        "apple",
        "airplay",
        "tv",
        "apple tv",
        "homekit"
    ],
    "files": [
        "dist",
        "CODEOWNERS",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "bun -b build.ts"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "typings": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "dependencies": {
        "@noble/curves": "^2.0.1",
        "@plist/binary.parse": "^1.1.0",
        "@plist/binary.serialize": "^1.1.0",
        "chacha": "^2.1.0",
        "fast-srp-hap": "^2.0.4",
        "node-dns-sd": "^1.0.1",
        "tweetnacl": "^1.0.3",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@basmilius/tools": "^2.13.0",
        "@types/bun": "^1.3.1"
    }
}
