{
    "name": "@basmilius/apple-common",
    "description": "Common features shared across various apple protocol packages.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/basmilius/apple-protocols",
        "directory": "packages/common"
    },
    "keywords": [
        "apple",
        "airplay",
        "tv",
        "apple tv",
        "homekit"
    ],
    "files": [
        "dist",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": false
    },
    "scripts": {
        "build": "tsgo --noEmit && tsdown",
        "dev": "tsdown --watch",
        "test:discovery": "bun --watch test-discovery.ts"
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "typings": "./dist/index.d.mts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        }
    },
    "dependencies": {
        "@basmilius/apple-encoding": "workspace:*",
        "@basmilius/apple-encryption": "workspace:*"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@types/node": "^25.5.0",
        "fast-srp-hap": "^2.0.4",
        "tsdown": "^0.21.6",
        "uuid": "^13.0.0"
    }
}
