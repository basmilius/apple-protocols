{
    "compilerOptions": {
        "target": "esnext",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": false,
        "skipLibCheck": true,
        "strict": false,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": false,
        "isolatedModules": true,
        "rootDir": ".",
        "outDir": "dist",
        "experimentalDecorators": true,
        "noEmit": true,
        "paths": {
            "@basmilius/apple-*": ["../*/src"]
        },
        "types": [
            "node"
        ]
    },
    "include": [
        "src/**/*.ts",
        "test/**/*.ts",
        "test-*.ts"
    ],
    "exclude": [
        "dist",
        "node_modules"
    ]
}
