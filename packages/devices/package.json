{
    "name": "@basmilius/apple-devices",
    "description": "Deprecated: use @basmilius/apple-sdk instead.",
    "deprecated": "Use @basmilius/apple-sdk instead.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/basmilius/apple-protocols",
        "directory": "packages/devices"
    },
    "keywords": [
        "apple",
        "airplay",
        "companion link",
        "tv",
        "apple tv",
        "homekit",
        "homepod",
        "homepod mini"
    ],
    "files": [
        "dist",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": false
    },
    "scripts": {
        "build": "tsgo --noEmit && tsdown",
        "dev": "tsdown --watch",
        "test:appletv": "bun --watch src/test-appletv.ts",
        "test:homepod": "bun --watch src/test-homepod.ts"
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "typings": "./dist/index.d.mts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        }
    },
    "dependencies": {
        "@basmilius/apple-airplay": "workspace:*",
        "@basmilius/apple-common": "workspace:*",
        "@basmilius/apple-companion-link": "workspace:*",
        "@basmilius/apple-encoding": "workspace:*"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@types/node": "^25.5.0",
        "tsdown": "^0.21.4"
    }
}
