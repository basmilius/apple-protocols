{
    "name": "@basmilius/apple-devices",
    "description": "Exposes various Apple devices to connect with either AirPlay or Companion Link.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "keywords": [
        "apple",
        "airplay",
        "companion link",
        "tv",
        "apple tv",
        "homekit",
        "homepod",
        "homepod mini"
    ],
    "files": [
        "dist",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "bun -b build.ts",
        "watch:test": "bun --watch src/test.ts"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "typings": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "dependencies": {
        "@basmilius/apple-airplay": "workspace:*",
        "@basmilius/apple-common": "workspace:*",
        "@basmilius/apple-companion-link": "workspace:*"
    },
    "devDependencies": {
        "@basmilius/tools": "^2.13.0",
        "@types/bun": "^1.3.1"
    }
}
