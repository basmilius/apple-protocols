{
    "compilerOptions": {
        "target": "esnext",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": false,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": false,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "rootDir": ".",
        "outDir": "dist",
        "declaration": true,
        "declarationDir": "dist",
        "emitDeclarationOnly": true,
        "experimentalDecorators": true,
        "noEmit": true,
        "paths": {
            "@basmilius/apple-*": ["../*/src"]
        },
        "types": [
            "node"
        ]
    },
    "include": [
        "src/**/*.ts",
        "test/**/*.ts",
        "build.ts"
    ],
    "exclude": [
        "dist",
        "node_modules"
    ]
}
