{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "isolatedModules": true,
        "skipLibCheck": true,
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "$flux/*": [
                "../../../node_modules/@flux-ui/components/src/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.vue",
        "env.d.ts"
    ]
}