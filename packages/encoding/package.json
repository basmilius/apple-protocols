{
    "name": "@basmilius/apple-encoding",
    "description": "Common encoding utilities for Apple Protocols.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/basmilius/apple-protocols",
        "directory": "packages/encoding"
    },
    "keywords": [
        "apple",
        "airplay",
        "companion link",
        "opack",
        "plist",
        "tlv8"
    ],
    "files": [
        "dist",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": false
    },
    "scripts": {
        "build": "tsgo --noEmit && tsdown",
        "dev": "tsdown --watch"
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "typings": "./dist/index.d.mts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        }
    },
    "devDependencies": {
        "@plist/binary.parse": "^1.1.0",
        "@plist/binary.serialize": "^1.1.0",
        "@types/bun": "^1.3.11",
        "@types/node": "^25.5.0",
        "tsdown": "^0.21.6"
    }
}
