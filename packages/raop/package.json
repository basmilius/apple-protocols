{
    "name": "@basmilius/apple-raop",
    "description": "Implementation of Apple's RAOP protocol in Node.js.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "keywords": [
        "apple",
        "raop",
        "airplay",
        "tv",
        "apple tv",
        "homekit"
    ],
    "files": [
        "dist",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": false
    },
    "scripts": {
        "build": "tsgo --noEmit && tsdown",
        "dev": "tsdown --watch",
        "watch:test": "bun --watch test.ts"
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "typings": "./dist/index.d.mts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        }
    },
    "dependencies": {
        "@basmilius/apple-common": "workspace:*",
        "@basmilius/apple-encoding": "workspace:*",
        "@basmilius/apple-encryption": "workspace:*"
    },
    "devDependencies": {
        "@types/bun": "^1.3.9",
        "tsdown": "^0.21.0-beta.2"
    }
}
